{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aria",
  "version": "0.1.10",
  "identifier": "com.aria.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aria Super Companion",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "shortDescription": "Aria AI companion desktop app",
    "createUpdaterArtifacts": false
  }
}
