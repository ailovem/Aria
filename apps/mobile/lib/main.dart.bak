class AriaMobileShell extends StatefulWidget {
  const AriaMobileShell({super.key});

  @override
  State<AriaMobileShell> createState() => _AriaMobileShellState();
}

class _AriaMobileShellState extends State<AriaMobileShell> {
  int _tabIndex = 0;
  CompanionScene _activeScene = kCompanionScenes.first;

  void _onSceneSelected(CompanionScene scene) {
    setState(() {
      _activeScene = scene;
      _tabIndex = 0;
    });
  }

  void _openScenePicker() {
    showModalBottomSheet<void>(
      context: context,
      showDragHandle: true,
      backgroundColor: const Color(0xFFF9F4EE),
      builder: (BuildContext context) {
        return ScenePickerSheet(
          activeScene: _activeScene,
          onSelected: (CompanionScene scene) {
            Navigator.of(context).pop();
            _onSceneSelected(scene);
          },
        );
      },
    );
  }

  void _openVoiceCall() {
    Navigator.of(context).push(
      MaterialPageRoute<void>(
        builder: (BuildContext context) => VoiceCallPage(scene: _activeScene),
      ),
    );
  }

  void _openActionBrief(CenterAction action) {
    ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text("已打开 ${action.title}")));
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: IndexedStack(
        index: _tabIndex,
        children: <Widget>[
          CompanionChatPage(
            scene: _activeScene,
            onOpenScenePicker: _openScenePicker,
            onOpenVoiceCall: _openVoiceCall,
          ),
          ServiceCenterPage(
            onActionTap: _openActionBrief,
          ),
        ],
      ),
      bottomNavigationBar: NavigationBar(
        height: 66,
        selectedIndex: _tabIndex,
        onDestinationSelected: (int value) {
          setState(() {
            _tabIndex = value;
          });
        },
        destinations: const <NavigationDestination>[
          NavigationDestination(icon: Icon(Icons.chat_bubble_outline_rounded), selectedIcon: Icon(Icons.chat_bubble_rounded), label: "首页"),
          NavigationDestination(icon: Icon(Icons.grid_view_rounded), selectedIcon: Icon(Icons.grid_view_rounded), label: "服务"),
        ],
      ),
    );
  }
}

class CompanionChatPage extends StatefulWidget {
  const CompanionChatPage({
    super.key,
    required this.scene,
    required this.onOpenScenePicker,
    required this.onOpenVoiceCall,
  });

  final CompanionScene scene;
  final VoidCallback onOpenScenePicker;
  final VoidCallback onOpenVoiceCall;

  @override
  State<CompanionChatPage> createState() => _CompanionChatPageState();
}

class _CompanionChatPageState extends State<CompanionChatPage> {
  final DemoApiClient _api = DemoApiClient();
  final TextEditingController _textController = TextEditingController();
  final ScrollController _scrollController = ScrollController();

  List<DemoMessage> _messages = <DemoMessage>[];
  bool _loading = true;
  bool _sending = false;
  String _errorText = "";

  @override
  void initState() {
    super.initState();
    _loadMessages();
  }

  @override
  void didUpdateWidget(covariant CompanionChatPage oldWidget) {
    super.didUpdateWidget(oldWidget);
    if (oldWidget.scene.id != widget.scene.id) {
      _appendLocalMessage(
        role: "aria",
        text: "已切换到「${widget.scene.title}」：${widget.scene.welcome}",
      );
    }
  }

  @override
  void dispose() {
    _api.dispose();
    _textController.dispose();
    _scrollController.dispose();
    super.dispose();
  }

  Future<void> _loadMessages() async {
    setState(() { _loading = true; _errorText = ""; });
    try {
      final state = await _api.fetchState();
      if (!mounted) return;
      setState(() {
        _messages = state.messages.isEmpty
            ? <DemoMessage>[_localBotMessage(widget.scene.welcome)]
            : state.messages;
        _loading = false;
      });
      _scrollToBottom();
    } catch (error) {
      if (!mounted) return;
      setState(() {
        if (_messages.isEmpty) _messages = [_localBotMessage(widget.scene.welcome)];
        _errorText = "同步失败：$error";
        _loading = false;
      });
    }
  }

  DemoMessage _localBotMessage(String text) => DemoMessage(id: "bot-${DateTime.now().microsecondsSinceEpoch}", role: "aria", text: text, time: _timeNow());
  DemoMessage _localUserMessage(String text) => DemoMessage(id: "user-${DateTime.now().microsecondsSinceEpoch}", role: "user", text: text, time: _timeNow());
  String _timeNow() { final now = DateTime.now(); return "${now.hour.toString().padLeft(2, '0')}:${now.minute.toString().padLeft(2, '0')}"; }

  void _appendLocalMessage({required String role, required String text}) {
    setState(() => _messages = [..._messages DemoMessage(id: "loc-${DateTime.now().microsecondsSinceEpoch}", role: role, text: text, time: _timeNow())]);
    _scrollToBottom();
  }

  void _scrollToBottom() {
    WidgetsBinding.instance.addPostFrameCallback((_) {
      if (!_scrollController.hasClients) return;
      final double offset = _scrollController.position.maxScrollExtent + 120;
      _scrollController.animateTo(offset, duration: const Duration(milliseconds: 300), curve: Curves.easeOut);
    });
  }

  Future<void> _sendText({String? preset}) async {
    final String text = (preset ?? _textController.text).trim();
    if (text.isEmpty || _sending) return;
    if (preset == null) _textController.clear();

    setState(() {
      _errorText = "";
      _sending = true;
      _messages = [..._messages _localUserMessage(text)];
    });
    _scrollToBottom();

    try {
      final state = await _api.sendMessage(text: text);
      if (!mounted) return;
      setState(() => _messages = state.messages);
      _scrollToBottom();
    } catch (error) {
      if (!mounted) return;
      setState(() {
        _errorText = "发送失败：$error";
        _messages = [..._messages _localBotMessage("我收到了，但网络刚刚抖了一下。再说一次？")];
      });
      _scrollToBottom();
    } finally {
      if (mounted) setState(() => _sending = false);
    }
  }

  void _fireEmotionalAction(String feeling, String contextMsg) {
    ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text(contextMsg), duration: const Duration(seconds: 1)));
    _sendText(preset: "*$feeling*");
  }

  @override
  Widget build(BuildContext context) {
    return Container(
      decoration: BoxDecoration(
        gradient: LinearGradient(
          begin: Alignment.topCenter,
          end: Alignment.bottomCenter,
          colors: [widget.scene.gradientStart, widget.scene.gradientEnd],
          stops: const [0.0, 0.4],
        ),
      ),
      child: SafeArea(
        bottom: false,
        child: Column(
          children: [
            _CompanionHeroHeader(
              scene: widget.scene,
              onHeartPressed: widget.onOpenScenePicker,
              onCallPressed: widget.onOpenVoiceCall,
              onActionTap: _fireEmotionalAction,
            ),
            if (_errorText.isNotEmpty)
              Container(
                margin: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
                padding: const EdgeInsets.all(10),
                color: Colors.red.withValues(alpha: 0.1),
                child: Text(_errorText, style: const TextStyle(color: Colors.redAccent, fontSize: 12)),
              ),
            Expanded(
              child: _loading
                  ? const Center(child: CircularProgressIndicator())
                  : _MessageList(messages: _messages, sending: _sending, controller: _scrollController),
            ),
            _ComposerArea(
              controller: _textController,
              onSubmit: _sendText,
              onVoiceTap: () {},
              onPlusTap: () {},
            ),
          ],
        ),
      ),
    );
  }
}

