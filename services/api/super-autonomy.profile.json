  "stabilityPolicy": {
    "targetSlo": {
      "p95LatencyMs": 2500,
      "maxFailureRate": 0.03
    },
    "queue": {
      "retryBudgetPerTask": 3,
      "backoffMs": 1200,
      "deadLetterReplayEnabled": true
    },
    "circuitBreaker": {
      "failureThreshold": 3,
      "coolDownMs": 45000
    }
  },
  "extensionFreedomPolicy": {
    "extensibilityLevel": "high",
    "sandboxRequired": true,
    "signatureRequiredForPrivileged": true,
    "pluginApiVersion": "v1",
    "approvedExtensionChannels": [
      "manifest",
      "github",
      "official-github",
      "mcp-catalog",
      "marketplace"
    ]
  },
  "duplicationGuard": {
    "disallowDuplicateImplementation": true,
    "preferReuseEndpoints": [
