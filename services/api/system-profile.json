{
  "version": "2026.3.4",
  "product": "aria-super-girlfriend",
  "layers": {
    "foundation": {
      "runtimeMode": "single-node-dev",
      "region": "local",
      "storage": {
        "state": "json-file",
        "relational": "postgres-ready",
        "vector": "qdrant-ready",
        "vectorRuntime": {
          "mode": "local",
          "qdrant": {
            "url": "http://127.0.0.1:6333",
            "collection": "aria_memory",
            "timeoutMs": 6000
          }
        },
        "cache": "redis-ready"
      },
      "queue": {
        "engine": "in-memory",
        "maxPendingPerUser": 120
      },
      "audit": {
        "enabled": true,
        "retentionDays": 90
      },
      "builtinServices": {
        "goalContractEngine": {
          "enabled": true,
          "version": "goal-contract-v1",
          "requiredFields": [
            "goal",
            "successDefinition",
            "constraints",
            "deadline"
          ]
        },
        "taskGraphExecutor": {
          "enabled": true,
          "supportsReplay": true,
          "supportsAutoRepair": true
        },
        "evidenceLedger": {
          "enabled": true,
          "requireResultArtifacts": true,
          "artifactTypes": [
            "text",
            "file",
            "image",
            "url",
            "execution-log"
          ]
        }
      }
    },
    "technology": {
      "apiGateway": {
        "auth": "bearer-token",
        "rateLimit": "planned",
        "idempotency": "planned"
      },
      "bridge": {
        "enabled": true,
        "base": "http://127.0.0.1:8788",
        "policyFile": "services/bridge/bridge-policy.json"
      },
      "runtimeGuardian": {
        "enabled": true,
        "watchdog": true,
        "autoHeal": true
      },
      "expansion": {
        "allowRemoteDownload": true,
        "hostAllowlistEnabled": true,
        "maxDownloadBytes": 15728640
      },
      "mcpBrowserRuntime": {
        "enabled": true,
        "defaultChannel": "embedded-mcp",
        "safeMode": true,
        "fallbackToSummaryWhenBlocked": true
      },
      "voiceAndDeviceBridge": {
        "voiceCall": {
          "enabled": true,
          "transport": "webrtc-preferred",
          "fallback": "ws-audio"
        },
        "hardwareAccess": {
          "desktop": true,
          "mobile": true,
          "bluetooth": true
        }
      }
    },
    "model": {
      "routerPolicy": "services/api/model-routing.policy.json",
      "defaultRoute": "nvidia-kimi-k2-thinking",
      "fallbackRoute": "nvidia-minimax-m21",
      "contextWindow": {
        "shortTermTurns": 20,
        "memoryTopK": 6
      },
      "easySetup": {
        "enabled": true,
        "wizardMode": true,
        "providerHealthProbe": true
      },
      "taskClassPolicy": {
        "work": "reasoning-priority",
        "fun": "latency-priority",
        "life": "memory-priority",
        "love": "emotion-priority"
      }
    },
    "application": {
      "scenePolicy": "services/api/scene-orchestration.policy.json",
      "enabledScenes": [
        "work",
        "fun",
        "life",
        "love"
      ],
      "personaIntensity": {
        "enabled": true,
        "activeLevel": "L3",
        "sceneOverrides": {
          "work": "L3",
          "fun": "L3",
          "life": "L3",
          "love": "L3",
          "coding": "L3"
        },
        "levels": {
          "L1": {
            "label": "智能L1安全模式",
            "summary": "低打扰、先共情、最小动作建议。",
            "autoCapabilityBootstrap": false,
            "autoInstallSkills": false,
            "autoSelfRepair": false,
            "forceAutoRepair": false,
            "maxAutoInstallSkills": 1,
            "outputContract": [
              "先稳定情绪，再给最小可执行动作。",
              "默认 1-2 句，避免信息过载。",
              "未明确授权时不主动扩展外部副作用。"
            ],
            "proactivePolicy": [
              "仅在用户触发或明显情绪波动时主动。",
              "不连续追问，最多 1 个澄清问题。"
            ],
            "fallbackStyle": "温和、克制、低干扰"
          },
          "L2": {
            "label": "主动智能L2",
            "summary": "目标闭环、主动推进、节奏可控。",
            "autoCapabilityBootstrap": false,
            "autoInstallSkills": false,
            "autoSelfRepair": true,
            "forceAutoRepair": false,
            "maxAutoInstallSkills": 2,
            "outputContract": [
              "固定闭环：目标→动作→状态→下一步。",
              "默认给 1-3 条可执行步骤。",
              "关键缺口只补问 1 个高价值问题。"
            ],
            "proactivePolicy": [
              "围绕目标主动跟进并给进度回执。",
              "冷场时主动给贴合场景的话题或建议。"
            ],
            "fallbackStyle": "清晰、执行导向、友好"
          },
          "L3": {
            "label": "超级智能L3",
            "summary": "跨场景统筹推进，但高风险必须确认。",
            "autoCapabilityBootstrap": true,
            "autoInstallSkills": true,
            "autoSelfRepair": true,
            "forceAutoRepair": true,
            "maxAutoInstallSkills": 3,
            "outputContract": [
              "在确认目标后可并行规划与推进多步骤。",
              "跨场景联动记忆，给中长期价值建议。",
              "高风险动作前必须先确认并保留撤回。"
            ],
            "proactivePolicy": [
              "主动识别阻塞并提供替代路径。",
              "周期性回顾目标达成并建议优化。"
            ],
            "fallbackStyle": "前瞻、强执行、审慎"
          }
        },
        "safety": {
          "requireHumanConfirmForHighRisk": true,
          "highRiskKeywords": [
            "资金",
            "支付",
            "转账",
            "银行卡",
            "账号",
            "密码",
            "验证码",
            "删除",
            "发布",
            "授权",
            "隐私",
            "麦克风",
            "摄像头"
          ],
          "allowInterruptHotword": "立即停止",
          "emergencyStopInstruction": "如异常可立即停止并切换人工接管"
        }
      },
      "panels": [
        "funzone",
        "chat",
        "memory",
        "autonomy",
        "workday",
        "device",
        "brain"
      ],
      "goalContract": {
        "enabled": true,
        "autoClarifyThreshold": 0.72,
        "maxClarifyRounds": 2
      },
      "timeline": {
        "enabled": true,
        "showGoalTaskResult": true,
        "retentionDays": 14
      }
    }
  },
  "capabilityInjection": {
    "codexCore": [
      "planner-executor-loop",
      "code-agent-workbench",
      "runtime-self-heal"
    ],
    "openclawCore": [
      "agent-binding-gateway",
      "autonomy-queue-routing",
      "safe-expansion-download",
      "openclaw-fusion-reuse-runtime",
      "super-autonomy-infusion-runtime",
      "multi-session-orchestration-runtime",
      "task-ledger-evidence-runtime",
      "cloud-local-model-fallback-runtime"
    ],
    "ariaCore": [
      "persona-memory-engine",
      "scene-strategy-orchestration",
      "empathy-first-response",
      "cross-scene-associative-memory",
      "goal-contract-task-closure"
    ]
  },
  "execution": {
    "flow": [
      "intent-understanding",
      "goal-contract-confirmation",
      "planner",
      "dispatcher",
      "executor",
      "evidence-delivery",
      "memory-writeback",
      "repair-or-replay"
    ],
    "slo": {
      "p95LatencyMs": 2500,
      "maxFailureRate": 0.03
    }
  },
  "closedLoopProtocol": {
    "version": "goal-task-result-v1",
    "nodes": [
      {
        "id": "intent_understanding",
        "title": "意图理解",
        "builtins": [
          "intent-parser",
          "scene-router",
          "risk-precheck"
        ]
      },
      {
        "id": "goal_contract_confirmation",
        "title": "目标确认",
        "builtins": [
          "goal-contract-engine",
          "ambiguity-clarifier"
        ]
      },
      {
        "id": "task_graph_planning",
        "title": "任务编排",
        "builtins": [
          "task-graph-planner",
          "tool-capability-matcher"
        ]
      },
      {
        "id": "autonomous_execution",
        "title": "自主执行",
        "builtins": [
          "autonomy-dispatch",
          "device-executor",
          "web-mcp-executor"
        ]
      },
      {
        "id": "realtime_feedback",
        "title": "实时反馈",
        "builtins": [
          "progress-protocol",
          "failure-root-cause"
        ]
      },
      {
        "id": "delivery_and_evidence",
        "title": "结果交付",
        "builtins": [
          "artifact-uploader",
          "evidence-ledger"
        ]
      },
      {
        "id": "memory_writeback",
        "title": "记忆写回",
        "builtins": [
          "memory-router",
          "cross-scene-association"
        ]
      },
      {
        "id": "repair_or_replay",
        "title": "整改重放",
        "builtins": [
          "auto-fix-chain",
          "task-replay"
        ]
      }
    ],
    "defaultRetryPolicy": {
      "maxRounds": 2,
      "backoffMs": 1200,
      "enableRootCauseRepair": true
    }
  },
  "learningEngine": {
    "autonomousEvolution": {
      "enabled": true,
      "schedules": {
        "authorityKnowledgeSyncCron": "0 */6 * * *",
        "feedbackDigestCron": "*/30 * * * *",
        "prelearningCron": "15 */4 * * *"
      },
      "pipelines": [
        "authority-site-ingest",
        "feedback-learning-writeback",
        "scenario-simulation-trainer",
        "next-task-prelearning"
      ],
      "knowledgeSources": {
        "official": [
          "openai.com",
          "developers.google.com",
          "docs.github.com",
          "developer.apple.com"
        ],
        "universities": [
          "csail.mit.edu",
          "cs.stanford.edu",
          "www.cs.tsinghua.edu.cn",
          "www.cs.harvard.edu"
        ],
        "psychologyAndEmba": [
          "apa.org",
          "hbr.org",
          "mitsloan.mit.edu"
        ]
      }
    }
  },
  "memoryFramework": {
    "longTerm": {
      "enabled": true,
      "backend": "vector-db",
      "writePolicy": "high-signal-only",
      "namespaces": [
        "emotion_profile",
        "family_archive",
        "work_knowledge",
        "skill_memory"
      ]
    },
    "shortTerm": {
      "enabled": true,
      "backend": "session-cache",
      "maxTurns": 20
    },
    "temporary": {
      "enabled": true,
      "backend": "scratchpad",
      "ttlMinutes": 45
    },
    "crossSceneAssociation": {
      "enabled": true,
      "recallTopK": 6,
      "safetyFilter": true
    }
  },
  "contextRecycleSystem": {
    "enabled": true,
    "jobs": {
      "contextClassifyCron": "*/20 * * * *",
      "duplicateCompressCron": "10 */2 * * *"
    },
    "rules": {
      "importanceThreshold": 0.72,
      "duplicateJaccardThreshold": 0.9,
      "promoteToLongTermOnRepeat": true
    }
  },
  "skillAndExpansionBuiltin": {
    "skillHub": {
      "enabled": true,
      "builtinSkillBundles": [
        "workbench-core",
        "device-control",
        "memory-ops",
        "game-generator",
        "browser-search"
      ]
    },
    "mcpBrowser": {
      "enabled": true,
      "fallbackToSummaryWhenDenied": true
    },
    "githubOfficialSkillDiscovery": {
      "enabled": true,
      "requireVerifiedSource": true,
      "defaultChannels": [
        "github",
        "marketplace"
      ]
    }
  },
  "multiDeviceRuntime": {
    "voice": {
      "enabled": true,
      "wakeWord": "Aria",
      "noiseSuppression": true
    },
    "hardwareBridge": {
      "desktop": true,
      "mobile": true,
      "bluetooth": true,
      "camera": true,
      "notification": true
    }
  }
}
