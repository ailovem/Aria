# Copy this file to one of:
# 1) .runtime/secrets/model-providers.env   (recommended)
# 2) .runtime/model-providers.env
#
# Keep only providers you want to enable. Empty values are ignored.

# Alibaba Bailian / DashScope (OpenAI compatible endpoint)
ARIA_MODEL_PROVIDER_CN_ALIYUN_QWEN_PLUS_API_KEY=

# DeepSeek official
ARIA_MODEL_PROVIDER_CN_DEEPSEEK_CHAT_API_KEY=

# Zhipu BigModel
ARIA_MODEL_PROVIDER_CN_ZHIPU_GLM_4_PLUS_API_KEY=

# SiliconFlow (if user says "feiliu", this is usually the platform)
ARIA_MODEL_PROVIDER_CN_SILICONFLOW_DEEPSEEK_V3_API_KEY=
ARIA_MODEL_PROVIDER_CN_SILICONFLOW_QWEN_API_KEY=

# iFlow shared key (one key can drive multiple iFlow models)
ARIA_MODEL_PROVIDER_IFLOW_SHARED_API_KEY=

# Optional override (normally do not need to change model/base URL)
# ARIA_MODEL_PROVIDER_CN_ALIYUN_QWEN_PLUS_MODEL=qwen-plus
# ARIA_MODEL_PROVIDER_CN_ALIYUN_QWEN_PLUS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ARIA_MODEL_PROVIDER_CN_DEEPSEEK_CHAT_MODEL=deepseek-chat
# ARIA_MODEL_PROVIDER_CN_DEEPSEEK_CHAT_BASE_URL=https://api.deepseek.com/v1
# ARIA_MODEL_PROVIDER_CN_ZHIPU_GLM_4_PLUS_MODEL=glm-4-plus
# ARIA_MODEL_PROVIDER_CN_ZHIPU_GLM_4_PLUS_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ARIA_MODEL_PROVIDER_CN_SILICONFLOW_DEEPSEEK_V3_MODEL=deepseek-ai/DeepSeek-V3
# ARIA_MODEL_PROVIDER_CN_SILICONFLOW_DEEPSEEK_V3_BASE_URL=https://api.siliconflow.cn/v1
# ARIA_MODEL_PROVIDER_CN_SILICONFLOW_QWEN_MODEL=Qwen/Qwen2.5-72B-Instruct
# ARIA_MODEL_PROVIDER_CN_SILICONFLOW_QWEN_BASE_URL=https://api.siliconflow.cn/v1

# iFlow model examples (optional override)
# ARIA_MODEL_PROVIDER_IFLOW_QWEN3_CODER_PLUS_MODEL=Qwen3-Coder-Plus
# ARIA_MODEL_PROVIDER_IFLOW_QWEN3_MAX_MODEL=Qwen3-Max
# ARIA_MODEL_PROVIDER_IFLOW_KIMI_K2_INSTRUCT_0905_MODEL=Kimi-K2-Instruct-0905
# ARIA_MODEL_PROVIDER_IFLOW_DEEPSEEK_V3_2_EXP_MODEL=DeepSeek-V3.2-Exp
